@{
    ViewData["Title"] = "Home";
}
<div class="p-4 p-md-5 bg-light rounded-3 mb-4">
    <h1 class="display-6 mb-2">Homecare</h1>
    <p class="lead mb-0">Book and manage homecare appointments easily.</p>
</div>

<div class="row g-3">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body d-flex flex-column">
                <h5 class="card-title">Client Portal</h5>
                <p class="card-text">View and book appointments.</p>
                <a class="btn btn-primary mt-auto" asp-controller="Client" asp-action="Dashboard"
                    asp-route-clientId="10">Go to Client (Ali)</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body d-flex flex-column">
                <h5 class="card-title">Personnel Portal</h5>
                <p class="card-text">Create days (3 slots) and see bookings.</p>
                <a class="btn btn-primary mt-auto" asp-controller="Personnel" asp-action="Dashboard"
                    asp-route-personnelId="2">Go to Personnel (Nurse A)</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body d-flex flex-column">
                <h5 class="card-title">Admin</h5>
                <p class="card-text">Manage whole system.</p>
                <a class="btn btn-outline-primary mt-auto" asp-controller="Admin" asp-action="Dashboard">Go to Admin</a>
            </div>
        </div>
    </div>
</div>