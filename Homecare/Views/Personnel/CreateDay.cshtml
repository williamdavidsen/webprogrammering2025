@{
    ViewData["Title"] = "Create Day (3 slots)";
    var personnelId = (int)ViewBag.PersonnelId;
}
<h2 class="mb-3">@ViewData["Title"]</h2>

<form asp-action="CreateDay" method="post" class="mt-2">
    <input type="hidden" name="personnelId" value="@personnelId" />
    <div class="row g-3">
        <div class="col-sm-6 col-md-4">
            <label class="form-label">Day</label>
            <input name="day" class="form-control" type="date"
                value="@DateOnly.FromDateTime(DateTime.Today.AddDays(1)).ToString("yyyy-MM-dd")" required />
        </div>
    </div>
    <div class="mt-3 d-flex gap-2">
        <button class="btn btn-primary" type="submit">Create</button>
        <a class="btn btn-secondary" asp-action="Dashboard" asp-route-personnelId="@personnelId">Cancel</a>
    </div>
</form>