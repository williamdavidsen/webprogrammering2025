@{
    ViewData["Title"] = "My Appointments";
    var personnelId = (int)ViewBag.PersonnelId;
    var upcoming = (IEnumerable<Appointment>)ViewBag.Upcoming;
    var past = (IEnumerable<Appointment>)ViewBag.Past;
}
<h2 class="mb-3">My Appointments</h2>
<partial name="~/Views/Shared/_Message.cshtml" />

<div class="d-flex justify-content-end mb-3">
    <a class="btn btn-primary" asp-action="CreateDay" asp-route-personnelId="@personnelId">
        <i class="bi bi-calendar-plus"></i> Create Day (3 slots)
    </a>
</div>

<h5 class="mt-3">Upcoming</h5>
<div class="card mb-4">
    <div class="card-body p-0">
        <table class="table table-sm table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Day</th>
                    <th>Time</th>
                    <th>Client</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in upcoming)
                {
                    <tr>
                        <td>@a.AvailableSlot!.Day.ToString("yyyy-MM-dd")</td>
                        <td>@a.AvailableSlot!.StartTime - @a.AvailableSlot!.EndTime</td>
                        <td>@a.Client?.Name</td>
                        <td><span class="badge text-bg-secondary">@a.Status</span></td>
                    </tr>
                }
                @if (!upcoming.Any())
                {
                    <tr>
                        <td colspan="4" class="text-muted">No upcoming appointments.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<h5>Past</h5>
<div class="card">
    <div class="card-body p-0">
        <table class="table table-sm table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Day</th>
                    <th>Time</th>
                    <th>Client</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in past)
                {
                    <tr>
                        <td>@a.AvailableSlot!.Day.ToString("yyyy-MM-dd")</td>
                        <td>@a.AvailableSlot!.StartTime - @a.AvailableSlot!.EndTime</td>
                        <td>@a.Client?.Name</td>
                        <td><span class="badge text-bg-secondary">@a.Status</span></td>
                    </tr>
                }
                @if (!past.Any())
                {
                    <tr>
                        <td colspan="4" class="text-muted">No past appointments.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>