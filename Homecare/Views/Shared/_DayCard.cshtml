@model Homecare.Models.AvailableDay

<div class="card h-100">
    <div class="card-body d-flex flex-column">
        <div class="d-flex align-items-center mb-2">
            <div class="hc-role-icon me-2"><i class="bi bi-clipboard2-check"></i></div>
            <div>
                <div class="fw-semibold">@Model.PersonnelName</div>
                <div class="text-muted small">@Model.Day.ToString("yyyy-MM-dd")</div>
            </div>
        </div>

        <p class="text-muted small mb-3 flex-grow-1">
            Day has 3 fixed slots (1,2,3). Status:
            <span class="badge @(Model.Status == "Open" ? "text-bg-success" : "text-bg-secondary")">@Model.Status</span>
        </p>

        <div class="d-grid gap-2 mt-auto">
            <a class="btn btn-outline-primary btn-sm" asp-controller="AvailableDay" asp-action="Details"
                asp-route-id="@Model.AvailableDayId">
                View Details
            </a>
        </div>
    </div>
</div>