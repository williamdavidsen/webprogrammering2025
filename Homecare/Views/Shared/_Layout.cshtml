@* Views/Shared/_Layout.cshtml *@
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Homecare</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <!-- App CSS -->
    <link rel="stylesheet" href="~/css/home.css" asp-append-version="true">
</head>

<body class="d-flex flex-column min-vh-100">
    <!-- Header / Navbar -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
            <div class="container">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-hospital"></i> Homecare
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                    aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house-door"></i> Home
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="AvailableDay" asp-action="Table">
                                <i class="bi bi-calendar-plus"></i> Available Days
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Appointment" asp-action="Table">
                                <i class="bi bi-people"></i> Appointments
                            </a>
                        </li>
                    </ul>

                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Auth" asp-action="ClientLogin">
                                <i class="bi bi-person"></i> Client Login
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Auth" asp-action="PersonnelLogin">
                                <i class="bi bi-badge-hd"></i> Personnel Login
                            </a>
                        </li>
                    </ul>

                </div>
            </div>
        </nav>
    </header>

    <!-- Main -->
    <main class="container mt-4 flex-grow-1">
        @RenderBody()
    </main>
    <footer class="hc-foot mt-auto">
        <div class="container">
            <div class="row gy-4">
                <div class="col-12 col-lg-4">
                    <div class="d-flex align-items-center mb-2">
                        <i class="bi bi-hospital fs-4 me-2 text-light"></i>
                        <h5 class="mb-0">Homecare</h5>
                    </div>
                    <p>Your health companion, simplifying access to care.</p>
                </div>
                <div class="col-6 col-lg-2">
                    <h5>Quick Links</h5>
                    <ul class="list-unstyled">
                        <li><a asp-controller="Appointment" asp-action="Table">Book Appointment</a></li>
                        <li><a asp-controller="Appointment" asp-action="Table">My Appointments</a></li>
                        <li><a asp-controller="AvailableDay" asp-action="Table">Available Days</a></li>
                    </ul>
                </div>
                <div class="col-6 col-lg-2">
                    <h5>Company</h5>
                    <ul class="list-unstyled">
                        <li><a href="#">About Us</a></li>
                        <li><a href="#">Careers</a></li>
                        <li><a href="#">Contact</a></li>
                    </ul>
                </div>
                <div class="col-12 col-lg-4">
                    <h5>Follow Us</h5>
                    <div class="d-flex gap-3 fs-5">
                        <a href="#"><i class="bi bi-facebook"></i></a>
                        <a href="#"><i class="bi bi-twitter-x"></i></a>
                        <a href="#"><i class="bi bi-instagram"></i></a>
                    </div>
                </div>
            </div>

            <hr class="border-secondary-subtle mt-4" />
            <div class="d-flex flex-column flex-sm-row justify-content-between small gap-2">
                <span>© @DateTime.Now.Year Homecare. All rights reserved.</span>
                <span><a href="#">Privacy Policy</a> · <a href="#">Terms of Service</a></span>
            </div>
        </div>
    </footer>

    <!-- Bootstrap JS (bundle) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
        crossorigin="anonymous"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>