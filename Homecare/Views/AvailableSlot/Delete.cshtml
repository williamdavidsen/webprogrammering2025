@model AvailableSlot
@{
    ViewData["Title"] = "Delete Slot";
}
<h2 class="mb-3">Delete Slot</h2>
<p class="text-muted">Are you sure you want to delete this slot?</p>

<div class="card mb-3">
    <div class="card-body">
        <dl class="row">
            <dt class="col-4">Personnel</dt>
            <dd class="col-8">@Model.Personnel?.Name</dd>
            <dt class="col-4">Day</dt>
            <dd class="col-8">@Model.Day.ToString("yyyy-MM-dd")</dd>
            <dt class="col-4">Time</dt>
            <dd class="col-8">@Model.StartTime - @Model.EndTime</dd>
        </dl>
    </div>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="AvailableSlotId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a class="btn btn-secondary" asp-action="Table">Cancel</a>
</form>