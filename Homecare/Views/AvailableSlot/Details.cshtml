@model AvailableSlot
@{
    ViewData["Title"] = "Slot Details";
}
<h2 class="mb-3">Slot Details</h2>

<div class="card">
    <div class="card-body">
        <dl class="row">
            <dt class="col-4">Personnel</dt>
            <dd class="col-8">@Model.Personnel?.Name</dd>
            <dt class="col-4">Day</dt>
            <dd class="col-8">@Model.Day.ToString("yyyy-MM-dd")</dd>
            <dt class="col-4">Start</dt>
            <dd class="col-8">@Model.StartTime</dd>
            <dt class="col-4">End</dt>
            <dd class="col-8">@Model.EndTime</dd>
            <dt class="col-4">Booked</dt>
            <dd class="col-8">@((Model.Appointment != null) ? "Yes" : "No")</dd>
        </dl>
        <div class="d-flex gap-2">
            <a class="btn btn-secondary" asp-action="Table">Back</a>
            <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.AvailableSlotId">Edit</a>
        </div>
    </div>
</div>