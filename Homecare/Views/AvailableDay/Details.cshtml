@model Homecare.Models.AvailableDay
@{
    ViewData["Title"] = "Day Details";
}
<h2 class="mb-3">Available Day: @Model.Day.ToString("yyyy-MM-dd")</h2>

<div class="row g-3">
    <div class="col-12 col-lg-6">
        <div class="card">
            <div class="card-body">
                <dl class="row">
                    <dt class="col-4">Personnel</dt>
                    <dd class="col-8">@Model.PersonnelName</dd>
                    <dt class="col-4">Status</dt>
                    <dd class="col-8">
                        <span
                            class="badge @(Model.Status == "Open" ? "text-bg-success" : "text-bg-secondary")">@Model.Status</span>
                    </dd>
                    <dt class="col-4">Slots</dt>
                    <dd class="col-8">3 fixed slots (1,2,3)</dd>
                </dl>
                <div class="d-flex gap-2">
                    <a class="btn btn-outline-secondary" asp-controller="AvailableDay" asp-action="Table">Back to
                        Table</a>
                    <a class="btn btn-outline-secondary" asp-controller="AvailableDay" asp-action="Grid">Back to
                        Grid</a>
                </div>
            </div>
        </div>
    </div>
</div>