@model DayListViewModel
@{
    ViewData["Title"] = "Available Days (Grid)";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Available Days <small class="text-muted">(@Model.CurrentViewName view)</small></h2>
    <a class="btn btn-outline-secondary" asp-controller="AvailableDay" asp-action="Table">Table View</a>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    @foreach (var day in Model.Days)
    {
        <div class="col">
            @await Html.PartialAsync("_DayCard", day)
        </div>
    }
</div>