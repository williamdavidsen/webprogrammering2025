@model DayListViewModel
@{
    ViewData["Title"] = "Available Days (Table)";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Available Days <small class="text-muted">(@Model.CurrentViewName view)</small></h2>
    <a class="btn btn-outline-secondary" asp-controller="AvailableDay" asp-action="Grid">Grid View</a>
</div>

<div class="card">
    <div class="card-body p-0">
        @await Html.PartialAsync("_DayTable", Model.Days)
    </div>
</div>