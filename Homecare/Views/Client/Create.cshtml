@using Homecare.Models
@model Appointment
@{
    ViewData["Title"] = "Book Appointment";

    var clientId = (int)ViewBag.ClientId;
    var dayItems = ViewBag.DayItems as List<SelectListItem> ?? new();
    var slotItems = ViewBag.SlotItems as List<SelectListItem> ?? new();
    var taskOptions = ViewBag.TaskOptions as MultiSelectList;
}

<h2 class="mb-3">Book Appointment</h2>
<partial name="~/Views/Shared/_Message.cshtml" />

<form asp-action="Create" method="post" class="card p-3">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="ClientId" />

    <div class="row g-3">
        <div class="col-md-6">
            <label class="form-label">Day</label>
            <select id="daySelect" class="form-select">
                <option value="">Select a day...</option>
                @foreach (var it in dayItems)
                {
                    <option value="@it.Value" disabled="@(it.Disabled ? "disabled" : null)">
                        @it.Text
                    </option>
                }
            </select>
            <div class="form-text">Boş slotu olmayan günler pasiftir.</div>
        </div>

        <div class="col-md-6">
            <label asp-for="AvailableSlotId" class="form-label">Slot</label>
            <select asp-for="AvailableSlotId" class="form-select" id="slotSelect">
                <option value="">Önce gün seçiniz</option>
                @foreach (var s in slotItems)
                {
                    <option value="@s.Value">@s.Text</option>
                }
            </select>
            <span asp-validation-for="AvailableSlotId" class="text-danger"></span>
        </div>

        <div class="col-12">
            <label class="form-label">Requested Tasks</label>
            <select name="selectedTaskIds" multiple class="form-select">
                @if (taskOptions != null)
                {
                    foreach (var item in taskOptions)
                    {
                        <option value="@item.Value">@item.Text</option>
                    }
                }
            </select>
            <div class="form-text">Birden fazla görev seçebilirsiniz.</div>
        </div>

        <div class="col-12">
            <label asp-for="Description" class="form-label">Notes</label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
        </div>
    </div>

    <div class="mt-3 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Book</button>
        <a asp-action="Dashboard" asp-route-clientId="@clientId" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    <script>
        const daySelect = document.getElementById('daySelect');
        const slotSelect = document.getElementById('slotSelect');

        daySelect.addEventListener('change', async function () {
            const day = this.value;
            slotSelect.innerHTML = '<option value="">Loading...</option>';

            if (!day) {
                slotSelect.innerHTML = '<option value="">Önce gün seçiniz</option>';
                return;
            }

            try {
                const res = await fetch(`/Client/SlotsForDay?day=${encodeURIComponent(day)}`);
                const slots = await res.json();

                if (!slots || slots.length === 0) {
                    slotSelect.innerHTML = '<option value="">Bu gün için boş slot yok</option>';
                    return;
                }

                slotSelect.innerHTML = '';
                for (const s of slots) {
                    const opt = document.createElement('option');
                    opt.value = s.id;
                    opt.textContent = s.label;
                    slotSelect.appendChild(opt);
                }
            } catch (e) {
                slotSelect.innerHTML = '<option value="">Hata oluştu</option>';
            }
        });
    </script>
}