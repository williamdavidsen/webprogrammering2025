@{
    ViewData["Title"] = "My Appointments";
    var clientId = (int)ViewBag.ClientId;
    var upcoming = (IEnumerable<Appointment>)ViewBag.Upcoming;
    var past = (IEnumerable<Appointment>)ViewBag.Past;
}
<h2 class="mb-3">My Appointments</h2>
<partial name="~/Views/Shared/_Message.cshtml" />

<div class="d-flex justify-content-end mb-3">
    <a class="btn btn-primary" asp-action="Create" asp-route-clientId="@clientId">
        <i class="bi bi-plus-circle"></i> New Appointment
    </a>
</div>

<h5 class="mt-3">Upcoming</h5>
<div class="card mb-4">
    <div class="card-body p-0">
        <table class="table table-sm table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Day</th>
                    <th>Time</th>
                    <th>Personnel</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in upcoming)
                {
                    <tr>
                        <td>@a.AvailableSlot?.Day.ToString("yyyy-MM-dd")</td>
                        <td>@a.AvailableSlot?.StartTime - @a.AvailableSlot?.EndTime</td>
                        <td>@a.AvailableSlot?.Personnel?.Name</td>
                        <td><span class="badge text-bg-secondary">@a.Status</span></td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" asp-controller="Appointment" asp-action="Details"
                                asp-route-id="@a.AppointmentId">Details</a>
                            <a class="btn btn-sm btn-outline-secondary" asp-controller="Appointment" asp-action="Edit"
                                asp-route-id="@a.AppointmentId">Update</a>
                            <form asp-action="Delete" asp-route-id="@a.AppointmentId" method="post" class="d-inline">
                                <button class="btn btn-sm btn-outline-danger" type="submit">Delete</button>
                            </form>
                        </td>
                    </tr>
                }
                @if (!upcoming.Any())
                {
                    <tr>
                        <td colspan="5" class="text-muted">No upcoming appointments.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<h5>Past</h5>
<div class="card">
    <div class="card-body p-0">
        <table class="table table-sm table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Day</th>
                    <th>Time</th>
                    <th>Personnel</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var a in past)
                {
                    <tr>
                        <td>@a.AvailableSlot?.Day.ToString("yyyy-MM-dd")</td>
                        <td>@a.AvailableSlot?.StartTime - @a.AvailableSlot?.EndTime</td>
                        <td>@a.AvailableSlot?.Personnel?.Name</td>
                        <td><span class="badge text-bg-secondary">@a.Status</span></td>
                    </tr>
                }
                @if (!past.Any())
                {
                    <tr>
                        <td colspan="4" class="text-muted">No past appointments.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>